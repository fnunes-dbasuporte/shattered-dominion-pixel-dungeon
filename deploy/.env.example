# Modelo do .env de PRODUÇÃO — copiar para /opt/shattered-dominion/.env
# na VM e ajustar (sudo install -m 600). Nunca commitar o .env real.

NODE_ENV=production

# Porta interna do jogo — 3005 conforme o mapa de portas da VM.
PORT=3005

# Bind SEMPRE em loopback: quem expõe é o nginx (wss via /shattered-dominion-ws/).
BIND_ADDR=127.0.0.1
