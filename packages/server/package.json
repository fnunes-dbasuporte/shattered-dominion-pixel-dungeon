{
  "name": "@shattered-dominion/server",
  "version": "0.1.0",
  "private": true,
  "description": "Servidor autoritativo (Node 22 + Colyseus)",
  "license": "GPL-3.0-or-later",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "build:prod": "node scripts/build-prod.mjs",
    "start": "node dist/index.js",
    "start:prod": "node --max-old-space-size=256 dist-prod/server.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "loadtest": "tsx src/loadtest.ts"
  },
  "dependencies": {
    "@colyseus/core": "^0.17.44",
    "@colyseus/schema": "^4.0.27",
    "@colyseus/ws-transport": "^0.17.13",
    "@shattered-dominion/shared": "workspace:*",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@colyseus/testing": "^0.17.11",
    "@types/express": "^5.0.6",
    "@types/node": "^22.19.11",
    "esbuild": "^0.28.1",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
